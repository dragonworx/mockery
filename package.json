{
  "name": "http-request-mocker",
  "version": "1.0.0",
  "description": "Chrome extension to intercept HTTP requests and serve stubbed responses",
  "main": "mock-server.js",
  "scripts": {
    "start": "node mock-server.js",
    "kill": "pkill -f 'node mock-server.js' || true",
    "install-hot-reload": "npm install chokidar --save-optional"
  },
  "keywords": [
    "chrome-extension",
    "mock",
    "http",
    "requests",
    "testing",
    "stub"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=12.0.0"
  },
  "optionalDependencies": {
    "chokidar": "^3.5.3"
  }
}
{
  "name": "mockery",
  "version": "2.0.0",
  "description": "Chrome extension + Bun server to intercept HTTP requests and serve mock responses",
  "type": "module",
  "main": "server/index.ts",
  "scripts": {
    "start": "bun run server/index.ts",
    "dev": "bun --watch run server/index.ts",
    "test": "bun test",
    "kill": "pkill -f 'bun.*server/index.ts' || true"
  },
  "keywords": [
    "chrome-extension",
    "mock",
    "http",
    "requests",
    "testing",
    "stub",
    "bun"
  ],
  "author": "",
  "license": "ISC"
}

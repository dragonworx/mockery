{
  "name": "mockery",
  "version": "1.0.0",
  "description": "Chrome extension + Node.js server to intercept HTTP requests and serve mock responses",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "kill": "pkill -f 'node.*server/index.js' || true",
    "install-hot-reload": "npm install chokidar --save-optional"
  },
  "keywords": [
    "chrome-extension",
    "mock",
    "http",
    "requests",
    "testing",
    "stub"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=12.0.0"
  },
  "optionalDependencies": {
    "chokidar": "^3.5.3"
  }
}